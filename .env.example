# --- Database ---
POSTGRES_USER=ledger_admin
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=ledger_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://ledger_admin:change_me_in_prod@db:5432/ledger_db
ASYNC_DATABASE_URL=postgresql+asyncpg://ledger_admin:change_me_in_prod@db:5432/ledger_db

# --- App ---
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# --- Auth (JWT) ---
JWT_SECRET_KEY=change_me_super_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Redis (optional caching) ---
REDIS_URL=redis://redis:6379/0

# --- Idempotency ---
IDEMPOTENCY_KEY_TTL_HOURS=24

# --- FX ---
FX_RATE_STALE_THRESHOLD_HOURS=12
